{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/eric-stone-plus/HIGHBALL/schemas/route-policy-report.schema.json",
  "title": "HIGHBALL Route Policy Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_report_version",
    "route_group",
    "inputs",
    "calibration",
    "outcome",
    "baseline",
    "experiment_review",
    "execution",
    "policy_recommendation",
    "decision_reasons",
    "required_next_steps",
    "non_authorization"
  ],
  "properties": {
    "policy_report_version": {
      "type": "string",
      "const": "1.0"
    },
    "route_group": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "calibration_report_ref",
        "outcome_ledger_ref",
        "baseline_report_ref",
        "experiment_review_ref",
        "execution_report_ref"
      ],
      "properties": {
        "calibration_report_ref": {
          "type": "string",
          "minLength": 1
        },
        "outcome_ledger_ref": {
          "type": "string",
          "minLength": 1
        },
        "baseline_report_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "experiment_review_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "execution_report_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "calibration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommendation",
        "trace_count",
        "invalid_trace_files",
        "route_group_summary"
      ],
      "properties": {
        "recommendation": {
          "type": "string",
          "enum": [
            "adopt",
            "review",
            "reroute",
            "block",
            "no_data"
          ]
        },
        "trace_count": {
          "type": "integer",
          "minimum": 0
        },
        "invalid_trace_files": {
          "type": "integer",
          "minimum": 0
        },
        "route_group_summary": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "calibration_signal",
        "entry_count",
        "verified_positive_count",
        "verified_negative_count",
        "inconclusive_count",
        "regression_count"
      ],
      "properties": {
        "calibration_signal": {
          "type": "string",
          "enum": [
            "supports_route",
            "weakens_route",
            "mixed",
            "insufficient"
          ]
        },
        "entry_count": {
          "type": "integer",
          "minimum": 0
        },
        "verified_positive_count": {
          "type": "integer",
          "minimum": 0
        },
        "verified_negative_count": {
          "type": "integer",
          "minimum": 0
        },
        "inconclusive_count": {
          "type": "integer",
          "minimum": 0
        },
        "regression_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_count",
        "target_preferred_count",
        "baseline_preferred_count",
        "target_blocked_count",
        "watch_count",
        "insufficient_count",
        "recommendation"
      ],
      "properties": {
        "comparison_count": {
          "type": "integer",
          "minimum": 0
        },
        "target_preferred_count": {
          "type": "integer",
          "minimum": 0
        },
        "baseline_preferred_count": {
          "type": "integer",
          "minimum": 0
        },
        "target_blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "watch_count": {
          "type": "integer",
          "minimum": 0
        },
        "insufficient_count": {
          "type": "integer",
          "minimum": 0
        },
        "recommendation": {
          "type": "string",
          "enum": [
            "prefer_target",
            "prefer_baseline",
            "block_target",
            "watch",
            "insufficient",
            "not_provided"
          ]
        }
      }
    },
    "experiment_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_ref",
        "review_verdict",
        "policy_gate",
        "required_before_policy_change"
      ],
      "properties": {
        "review_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "review_verdict": {
          "type": "string",
          "enum": [
            "supports_policy_review",
            "needs_more_evidence",
            "stop_blocked",
            "plan_violation",
            "not_provided"
          ]
        },
        "policy_gate": {
          "type": "string",
          "enum": [
            "accepted",
            "watch",
            "block",
            "insufficient",
            "not_provided"
          ]
        },
        "required_before_policy_change": {
          "type": "boolean"
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_ref",
        "execution_gate",
        "packet_count",
        "required_execution_count",
        "complete_count",
        "missing_count",
        "blocked_count",
        "degraded_count",
        "invalid_count",
        "completion_rate"
      ],
      "properties": {
        "report_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "execution_gate": {
          "type": "string",
          "enum": [
            "accepted",
            "watch",
            "reroute",
            "block",
            "insufficient",
            "not_provided"
          ]
        },
        "packet_count": {
          "type": "integer",
          "minimum": 0
        },
        "required_execution_count": {
          "type": "integer",
          "minimum": 0
        },
        "complete_count": {
          "type": "integer",
          "minimum": 0
        },
        "missing_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "degraded_count": {
          "type": "integer",
          "minimum": 0
        },
        "invalid_count": {
          "type": "integer",
          "minimum": 0
        },
        "completion_rate": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "policy_recommendation": {
      "type": "string",
      "enum": [
        "keep",
        "watch",
        "reroute",
        "block",
        "insufficient"
      ]
    },
    "decision_reasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_next_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_authorization": {
      "type": "string",
      "minLength": 1
    }
  }
}
