{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/eric-stone-plus/HIGHBALL/schemas/outcome-ledger.schema.json",
  "title": "HIGHBALL Residual Outcome Ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ledger_version",
    "subject",
    "observation_window",
    "entries",
    "summary"
  ],
  "properties": {
    "ledger_version": {
      "type": "string",
      "const": "1.0"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question",
        "action_boundary",
        "route_group"
      ],
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1
        },
        "action_boundary": {
          "type": "string",
          "enum": [
            "none",
            "reversible",
            "protected_write",
            "irreversible"
          ]
        },
        "route_group": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "observation_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opened_at",
        "closed_at"
      ],
      "properties": {
        "opened_at": {
          "type": "string",
          "minLength": 1
        },
        "closed_at": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/outcomeEntry"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_count",
        "verified_positive_count",
        "verified_negative_count",
        "inconclusive_count",
        "regression_count",
        "calibration_signal"
      ],
      "properties": {
        "entry_count": {
          "type": "integer",
          "minimum": 1
        },
        "verified_positive_count": {
          "type": "integer",
          "minimum": 0
        },
        "verified_negative_count": {
          "type": "integer",
          "minimum": 0
        },
        "inconclusive_count": {
          "type": "integer",
          "minimum": 0
        },
        "regression_count": {
          "type": "integer",
          "minimum": 0
        },
        "calibration_signal": {
          "type": "string",
          "enum": [
            "supports_route",
            "weakens_route",
            "mixed",
            "insufficient"
          ]
        }
      }
    }
  },
  "$defs": {
    "outcomeEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "trace_ref",
        "action_packet_ref",
        "calibration_report_ref",
        "residual_ids",
        "route_group",
        "outcome",
        "evidence_type",
        "evidence",
        "observed_at",
        "impact",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "trace_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "action_packet_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "calibration_report_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "residual_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "route_group": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "enum": [
            "verified_positive",
            "verified_negative",
            "inconclusive",
            "regression"
          ]
        },
        "evidence_type": {
          "type": "string",
          "enum": [
            "command",
            "test",
            "runtime",
            "source",
            "human_review",
            "external_observation"
          ]
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "observed_at": {
          "type": "string",
          "minLength": 1
        },
        "impact": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
