{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/eric-stone-plus/HIGHBALL/schemas/route-pairing-report.schema.json",
  "title": "HIGHBALL Route Pairing Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pairing_report_version",
    "experiment_id",
    "route_group",
    "baseline_route_group",
    "action_boundary",
    "inputs",
    "pairs",
    "summary",
    "recommendation",
    "non_authorization"
  ],
  "properties": {
    "pairing_report_version": {
      "type": "string",
      "const": "1.0"
    },
    "experiment_id": {
      "type": "string",
      "minLength": 1
    },
    "route_group": {
      "type": "string",
      "minLength": 1
    },
    "baseline_route_group": {
      "type": "string",
      "minLength": 1
    },
    "action_boundary": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pair_manifest_ref"
      ],
      "properties": {
        "pair_manifest_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "pairs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pairResult"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "recommendation": {
      "type": "string",
      "enum": [
        "prefer_target",
        "prefer_baseline",
        "block_target",
        "block_baseline",
        "watch",
        "insufficient"
      ]
    },
    "non_authorization": {
      "type": "string",
      "const": "Route pairing reports do not authorize action, dispatch agents, or modify routing rules."
    }
  },
  "$defs": {
    "pairResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "question",
        "target_trace_ref",
        "baseline_trace_ref",
        "target",
        "baseline",
        "deltas",
        "verdict",
        "reasons"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "target_trace_ref": {
          "type": "string",
          "minLength": 1
        },
        "baseline_trace_ref": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "anyOf": [
            {
              "$ref": "#/$defs/traceScore"
            },
            {
              "type": "null"
            }
          ]
        },
        "baseline": {
          "anyOf": [
            {
              "$ref": "#/$defs/traceScore"
            },
            {
              "type": "null"
            }
          ]
        },
        "deltas": {
          "$ref": "#/$defs/deltas"
        },
        "verdict": {
          "type": "string",
          "enum": [
            "target_preferred",
            "baseline_preferred",
            "target_blocked",
            "baseline_blocked",
            "watch",
            "invalid"
          ]
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "traceScore": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_group",
        "instrument",
        "base_model_relation",
        "action_boundary",
        "quality_gate",
        "recommendation",
        "evidence_score",
        "residual_count",
        "action_blocking_count",
        "risk_penalty",
        "residuals_per_10k_tokens"
      ],
      "properties": {
        "route_group": {
          "type": "string",
          "minLength": 1
        },
        "instrument": {
          "type": "string",
          "minLength": 1
        },
        "base_model_relation": {
          "type": "string",
          "minLength": 1
        },
        "action_boundary": {
          "type": "string",
          "minLength": 1
        },
        "quality_gate": {
          "type": "string",
          "minLength": 1
        },
        "recommendation": {
          "type": "string",
          "minLength": 1
        },
        "evidence_score": {
          "$ref": "#/$defs/nullableNumber"
        },
        "residual_count": {
          "type": "integer",
          "minimum": 0
        },
        "action_blocking_count": {
          "type": "integer",
          "minimum": 0
        },
        "risk_penalty": {
          "$ref": "#/$defs/nullableNumber"
        },
        "residuals_per_10k_tokens": {
          "$ref": "#/$defs/nullableNumber"
        }
      }
    },
    "deltas": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_score",
        "residual_count",
        "action_blocking_count",
        "risk_penalty",
        "residuals_per_10k_tokens"
      ],
      "properties": {
        "evidence_score": {
          "$ref": "#/$defs/nullableNumber"
        },
        "residual_count": {
          "$ref": "#/$defs/nullableNumber"
        },
        "action_blocking_count": {
          "$ref": "#/$defs/nullableNumber"
        },
        "risk_penalty": {
          "$ref": "#/$defs/nullableNumber"
        },
        "residuals_per_10k_tokens": {
          "$ref": "#/$defs/nullableNumber"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pair_count",
        "target_preferred_count",
        "baseline_preferred_count",
        "target_blocked_count",
        "baseline_blocked_count",
        "watch_count",
        "invalid_pair_count",
        "minimum_pair_count",
        "minimum_pair_count_met"
      ],
      "properties": {
        "pair_count": {
          "type": "integer",
          "minimum": 0
        },
        "target_preferred_count": {
          "type": "integer",
          "minimum": 0
        },
        "baseline_preferred_count": {
          "type": "integer",
          "minimum": 0
        },
        "target_blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "baseline_blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "watch_count": {
          "type": "integer",
          "minimum": 0
        },
        "invalid_pair_count": {
          "type": "integer",
          "minimum": 0
        },
        "minimum_pair_count": {
          "type": "integer",
          "minimum": 0
        },
        "minimum_pair_count_met": {
          "type": "boolean"
        }
      }
    },
    "nullableNumber": {
      "type": [
        "number",
        "null"
      ]
    }
  }
}
